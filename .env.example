# =============================================================
# IRIS Regulação — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores
# NUNCA commite .env.local no git
# =============================================================

# ─── Supabase ────────────────────────────────────────────────
# Obtenha em: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Apenas server-side — NUNCA use NEXT_PUBLIC_ aqui
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Trigger.dev ─────────────────────────────────────────────
# Obtenha em: https://cloud.trigger.dev
TRIGGER_SECRET_KEY=tr_dev_...

# ─── Anthropic (IA para extração de PDF) ─────────────────────
# Obtenha em: https://console.anthropic.com/settings/keys
# Usado como fallback quando a confiança da extração regex < 70%
# Se não configurado, o sistema funciona apenas com extração por regex
ANTHROPIC_API_KEY=sk-ant-...
